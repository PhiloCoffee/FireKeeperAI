{
  "name": "firekeeper-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c amber,red \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:preview": "node scripts/preview-docs.mjs",
    "start": "npm run start -w apps/api",
    "test": "npm run test -w apps/api && npm run test -w apps/web"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "marked": "^18.0.5"
  }
}
